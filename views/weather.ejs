<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Weather - CaveSentry</title>
    <link rel="stylesheet" href="/styles.css">
</head>
<body>
    <header>
        <h1>CaveSentry Weather Portal</h1>
    </header>

    <main>
        <section class="form-section" style="text-align: center;">
            <h2>Current Weather for Cave Diving in <%= location %></h2>
            
            <div style="font-size: 24px; margin: 20px 0; color: #4db8ff;">
                <p><strong>Temperature:</strong> <%= weather.main.temp %>°C</p>
                <p><strong>Conditions:</strong> <%= weather.weather[0].description %></p>
            </div>
            
            <a href="/" style="display: inline-block; margin-top: 20px; background-color: #2b6cb0; color: #fff; padding: 10px 20px; border-radius: 4px; text-decoration: none;">
                &larr; Back to Safety Reports
            </a>
        </section>
    </main>
</body>
</html>
